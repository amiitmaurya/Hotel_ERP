@model Demo_Project.Models.RoomType

<link href="~/css/roomtypemaster/edit.css" rel="stylesheet" />
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="roomtype-container">

    <div class="page-header">

        <div>
            <h2>✏️ Edit Room Type</h2>
            <p>Update room category details and pricing information</p>
        </div>

    </div>

    <div class="roomtype-card">

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="mb-4">

                <label asp-for="RoomTypeName"
                       class="form-label">
                    Room Type Name
                </label>

                <input asp-for="RoomTypeName"
                       class="form-control custom-input"
                       placeholder="Enter room type name" required />


            </div>

            <div class="mb-4">

                <label asp-for="Description"
                       class="form-label">
                    Description
                </label>

                <textarea asp-for="Description"
                          rows="4"
                          class="form-control custom-input" required
                          placeholder="Enter room type description"></textarea>

            </div>

            <div class="row">

                <div class="col-md-6 mb-4">

                    <label asp-for="MaxGuests"
                           class="form-label">
                        Maximum Guests
                    </label>

                    <input asp-for="MaxGuests"
                           class="form-control custom-input" required />

                </div>

                <div class="col-md-6 mb-4">

                    <label asp-for="BasePrice"
                           class="form-label">
                        Base Price (₹)
                    </label>

                    <input asp-for="BasePrice"
                           class="form-control custom-input" required />

                </div>

            </div>

            <div class="status-box">

                <div class="form-check form-switch">

                    <input asp-for="IsActive"
                           class="form-check-input"
                           role="switch" />

                    <label asp-for="IsActive"
                           class="form-check-label">
                        Active Room Type
                    </label>

                </div>

            </div>

            <div class="action-buttons">

                <button type="submit"
                        class="btn-update">
                    Update Room Type
                </button>

                <a asp-action="Index"
                       class="btn-back">
                    Back
                </a>

            </div>

        </form>

    </div>

</div>