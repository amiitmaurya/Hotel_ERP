@model Demo_Project.Models.User


<link href="~/css/usermaster/create.css" rel="stylesheet" />
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="user-container">

    <div class="page-header">

        <div>
            <h2>👤 Create User</h2>
            <p>Add a new user and assign system permissions</p>
        </div>

    </div>

    <div class="user-card">

        <form asp-action="Create" method="post">

            <div class="row">

                <div class="col-md-6 mb-4">

                    <label class="form-label">
                        Full Name
                    </label>

                    <input asp-for="FullName"
                           class="form-control custom-input"
                           placeholder="Enter full name" required />

                    <span asp-validation-for="FullName"
                          class="text-danger"></span>

                </div>

                <div class="col-md-6 mb-4">

                    <label class="form-label">
                        Email Address
                    </label>

                    <input asp-for="Email"
                           class="form-control custom-input"
                           placeholder="Enter email address" required />

                </div>

                <div class="col-md-6 mb-4">

                    <label class="form-label">
                        Mobile Number
                    </label>

                    <input asp-for="Mobile"
                           class="form-control custom-input"
                           placeholder="Enter mobile number" required/>

                </div>

                <div class="col-md-6 mb-4">

                    <label class="form-label">
                        Username
                    </label>

                    <input asp-for="UserName"
                           class="form-control custom-input"
                           placeholder="Enter username" required />

                </div>

                <div class="col-md-6 mb-4">

                    <label class="form-label">
                        Password
                    </label>

                    <input asp-for="PasswordHash"
                           type="password"
                           class="form-control custom-input"
                           placeholder="Enter password" required />

                </div>

                <div class="col-md-6 mb-4">

                    <label class="form-label">
                        Role
                    </label>

                    <select asp-for="RoleId"
                            asp-items="ViewBag.Roles"
                            class="form-select custom-input" required>

                        <option value="">
                            -- Select Role --
                        </option>

                    </select>

                </div>

            </div>

            <div class="status-box">

                <div class="form-check form-switch">

                    <input asp-for="IsActive"
                           class="form-check-input"
                           role="switch" />

                    <label class="form-check-label">
                        Active User
                    </label>

                </div>

            </div>

            <div class="action-buttons">

                <button type="submit"
                        class="btn-save">
                    Save User
                </button>

                <a asp-action="Index"
                       class="btn-back">
                    Back
                </a>

            </div>

        </form>

    </div>

</div>