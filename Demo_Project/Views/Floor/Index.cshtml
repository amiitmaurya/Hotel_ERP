@model IEnumerable<Demo_Project.Models.Floor>

<link href="~/css/floormaster/index.css" rel="stylesheet" />
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="floor-wrapper">

    <div class="floor-header">

        <div>
            <h2>🏢 Floor Management</h2>
            <p>Manage hotel floors and availability status</p>
        </div>

        <a asp-action="Create"
               class="btn-create">
            + Add New Floor
        </a>

    </div>

    <div class="stats-box">
        Total Floors : @Model.Count()
    </div>

    <div class="table-responsive">

        <table class="floor-table">

            <thead>
                <tr>
                    <th>Floor Name</th>
                    <th>Floor Number</th>
                    <th>Status</th>
                    <th width="250">Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            <strong>@item.FloorName</strong>
                        </td>

                        <td>
                            Floor @item.FloorNumber
                        </td>

                        <td>

                            @if (item.IsActive)
                            {
                                <span class="status active">
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="status inactive">
                                    Inactive
                                </span>
                            }

                        </td>

                        <td>

                            <div class="action-buttons">


                                <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn-action edit">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       onclick="return confirm('Are you sure you want to delete this floor?')"
                                       class="btn-action delete">
                                    Delete
                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>