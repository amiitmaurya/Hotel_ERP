@model Demo_Project.Models.RoomImage

<link href="~/css/roomimages/delete.css" rel="stylesheet" />
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="delete-container">

    <div class="delete-card">

        <div class="delete-icon">
            🖼️
        </div>

        <h2>Delete Room Image</h2>

        <p class="delete-message">
            Are you sure you want to delete this room image?
        </p>

        <div class="image-preview-box">

            <img src="@Model.ImagePath"
                 class="preview-image"
                 alt="Room Image" />

        </div>

        <div class="warning-box">
            ⚠ This image will be permanently removed and cannot be recovered.
        </div>

        <form asp-action="Delete" method="post">

            <input asp-for="Id" type="hidden" />

            <div class="action-buttons">

                <button type="submit"
                        class="btn-delete">
                    Delete Image
                </button>

                <a asp-action="Index"
                       asp-route-roomId="@Model.RoomId"
                       class="btn-cancel">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>